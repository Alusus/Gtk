اشمل "./مشترك.أسس"؛
اشمل "../Glib/List.alusus"؛

@دمج عرف Glib: وحدة  {
    عرف قـائمة: لقب List؛
    @دمج عرف List: {
        عرف بيانات: لقب data؛
        عرف التالي: لقب next؛
        عرف السابق: لقب prev؛

        عرف ألحق: لقب append؛
        عرف استهل: لقب prepend؛
        عرف احشر: لقب insert؛
        عرف احشر_قبل: لقب insertBefore؛
        عرف احشر_بترتيب: لقب insertSorted؛
        عرف أزل: لقب remove؛
        عرف أزل_رابط: لقب removeLink؛
        عرف احذف_رابط: لقب deleteLink؛
        عرف أزل_الكل: لقب removeAll؛
        عرف حرر: لقب free؛
        عرف حرر_بشمول: لقب freeFull؛
        عرف احجز: لقب alloc؛
        عرف حرر_واحد: لقب freeOne؛
        عرف هات_الطول: لقب getLength؛
        عرف انسخ: لقب copy؛
        عرف انسخ_بعمق: لقب copyDeep؛
        عرف اعكس: لقب reverse؛
        عرف رتب: لقب sort؛
        عرف سلسل: لقب concat؛
        عرف لكل_من: لقب foreach؛
        عرف هات_الأول: لقب getFirst؛
        عرف هات_الأخير: لقب getLast؛
        عرف هات_محدد: لقب getNth؛
        عرف جد: لقب find؛
        عرف جد_مخصص: لقب findCustom؛
        عرف هات_الموقع: لقب getPosition؛
        عرف هات_التسلسل: لقب getIndex؛
    }؛
}

