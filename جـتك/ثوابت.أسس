اشمل "../Gtk/constants.alusus"؛

@دمج عرف Gtk: وحدة  {
    عرف إشـارة: {
        عرف _تفعيل_: لقب Signal.ACTIVATE؛
        عرف _نقر_: لقب Signal.CLICKED؛
        عرف _اختير_السطر_: لقب Signal.ROW_SELECTED؛
        عرف _تغير_: لقب Signal.CHANGED؛
        عرف _بدل_: لقب Signal.TOGGLED؛
    }؛

    عرف اتـجاه: {
        عرف _أفقي_: لقب Orientation.HORIZONTAL؛
        عرف _عمودي_: لقب Orientation.VERTICAL؛
    }؛

    عرف صـنف_رسالة: {
        عرف _معلومة_: لقب MessageType.INFO؛
        عرف _تحذير_: لقب MessageType.WARNING؛
        عرف _سؤال_: لقب MessageType.QUESTION؛
        عرف _خطأ_: لقب MessageType.ERROR؛
        عرف _أخرى_: لقب MessageType.OTHER؛
    }؛

    عرف نـوع_الزر: {
        عرف _بلا_: لقب ButtonsType.NONE؛
        عرف _اوكي_: لقب ButtonsType.OK؛
        عرف _أغلق_: لقب ButtonsType.CLOSE؛
        عرف _ألغ_: لقب ButtonsType.CANCEL؛
        عرف _نعم_لا_: لقب ButtonsType.YES_NO؛
        عرف _أوكي_ألغ_: لقب ButtonsType.OK_CANCEL؛
    }؛

    عرف طـراز_صندوق_الأزرار: {
        عرف _انتشار_: لقب ButtonBoxStyle.SPREAD؛
        عرف _حافة_: لقب ButtonBoxStyle.EDGE؛
        عرف _بداية_: لقب ButtonBoxStyle.START؛
        عرف _نهاية_: لقب ButtonBoxStyle.END؛
        عرف _وسط_: لقب ButtonBoxStyle.CENTER؛
        عرف _توسيع_: لقب ButtonBoxStyle.EXPAND؛
    }؛

    عرف نـمط_الاختيار: {
        عرف _بلا_: لقب SelectionMode.NONE؛
        عرف _مفرد_: لقب SelectionMode.SINGLE؛
        عرف _تصفح_: لقب SelectionMode.BROWSE؛
        عرف _متعدد_: لقب SelectionMode.MULTIPLE؛
    }؛

    عرف نـمط_اللف: {
        عرف _بلا_: لقب WrapMode.NONE؛
        عرف _محرف_: لقب WrapMode.CHAR؛
        عرف _كلمة_: لقب WrapMode.WORD؛
        عرف _كلمة_محرف_: لقب WrapMode.WORD_CHAR؛
    }؛

    عرف مـحاذاة: {
        عرف _يسار_: لقب Justification.LEFT؛
        عرف _يمين_: لقب Justification.RIGHT؛
        عرف _وسط_: لقب Justification.CENTER؛
        عرف _ملء_: لقب Justification.FILL؛
    }؛
}
